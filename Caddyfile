# Main domain - Frontend with API routing
acadistra.com, www.acadistra.com {
	# Route /logos/* and /photos/* to backend with proper headers
	handle /logos/* {
		header {
			Cache-Control "public, max-age=31536000, immutable"
			Access-Control-Allow-Origin "*"
		}
		reverse_proxy backend:8080
	}
	handle /photos/* {
		header {
			Cache-Control "public, max-age=31536000, immutable"
			Access-Control-Allow-Origin "*"
		}
		reverse_proxy backend:8080
	}
	
	# Route /api/* to backend
	handle /api/* {
		reverse_proxy backend:8080
	}
	
	# Everything else to frontend
	reverse_proxy frontend:3000
}

# API subdomain
api.acadistra.com {
	reverse_proxy backend:8080
}

# MinIO console
storage.acadistra.com {
	reverse_proxy minio:9001
}

# Wildcard for school subdomains
*.acadistra.com {
	reverse_proxy frontend:3000
}
