# ============================================
# MOBILE MONEY INTEGRATION (Flutterwave)
# ============================================

# Get these from: https://dashboard.flutterwave.com/settings/apis
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPT_KEY=FLWSECK_TESTxxxxxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret_here

# Webhook URL (must be publicly accessible)
PAYMENT_WEBHOOK_URL=https://yourschool.com/api/payments/webhook
PAYMENT_REDIRECT_URL=https://yourschool.com/payment/success

# ============================================
# SMS INTEGRATION (Africa's Talking)
# ============================================

# Get these from: https://account.africastalking.com/apps
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_USERNAME=sandbox  # Use 'sandbox' for testing, your username for production
AFRICASTALKING_SENDER_ID=YourSchool  # Must be approved by Africa's Talking

# ============================================
# EMAIL INTEGRATION (SMTP)
# ============================================

# Option 1: Gmail (Recommended for small schools)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password  # Generate from Google Account > Security > App Passwords
SMTP_FROM=noreply@yourschool.com

# Option 2: AWS SES (Recommended for production)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# SES_FROM_EMAIL=noreply@yourschool.com

# ============================================
# NOTIFICATION SETTINGS
# ============================================

# Enable/disable notification channels globally
NOTIFICATIONS_ENABLED=true
SMS_ENABLED=true
EMAIL_ENABLED=true

# Notification costs (for tracking)
SMS_COST_PER_MESSAGE=50  # UGX
EMAIL_COST_PER_MESSAGE=0  # Usually free

# ============================================
# PAYMENT SETTINGS
# ============================================

# Supported networks
SUPPORTED_NETWORKS=MTN,AIRTEL

# Transaction fees
MOBILE_MONEY_FEE_PERCENTAGE=1.4  # Flutterwave Uganda: 1.4%
MOBILE_MONEY_FEE_FIXED=0  # No fixed fee

# Payment limits
MIN_PAYMENT_AMOUNT=1000  # UGX
MAX_PAYMENT_AMOUNT=10000000  # UGX

# ============================================
# TESTING CREDENTIALS
# ============================================

# Flutterwave Test Cards
# Card: 4187427415564246
# CVV: 828
