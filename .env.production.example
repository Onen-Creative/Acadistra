# Production Environment Variables
# Copy this file to .env.production and fill in your actual credentials
# DO NOT commit .env.production to Git!

# ============================================
# CORE SERVICES
# ============================================

# PostgreSQL Database
POSTGRES_PASSWORD=your-secure-postgres-password-here

# Redis Cache
REDIS_PASSWORD=your-secure-redis-password-here

# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-secure-minio-password-here

# JWT Authentication
JWT_SECRET=your-secure-jwt-secret-min-32-characters-here

# ============================================
# EMAIL CONFIGURATION
# ============================================

# SMTP Settings (e.g., Gmail, SendGrid, AWS SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@acadistra.com

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================

# Africa's Talking SMS Provider
AFRICASTALKING_USERNAME=your-africastalking-username
AFRICASTALKING_API_KEY=your-africastalking-api-key
AFRICASTALKING_SENDER_ID=ACADISTRA

# Twilio SMS Provider (Alternative)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+256700000000

# ============================================
# SCHOOLPAY INTEGRATION (Optional)
# ============================================

# SchoolPay Uganda - Mobile Money Payments
SCHOOLPAY_API_KEY=your-schoolpay-api-key
SCHOOLPAY_API_SECRET=your-schoolpay-api-secret
SCHOOLPAY_MERCHANT_ID=your-merchant-id
SCHOOLPAY_WEBHOOK_SECRET=your-webhook-secret
SCHOOLPAY_BASE_URL=https://api.schoolpay.ug

# ============================================
# APPLICATION URLS
# ============================================

# Frontend URL
NEXT_PUBLIC_API_URL=https://acadistra.com
NEXT_PUBLIC_APP_URL=https://acadistra.com
NEXT_PUBLIC_SOCKET_URL=https://acadistra.com

# ============================================
# NOTES
# ============================================

# SMS Configuration:
# - Each school can configure their own SMS provider in the admin panel
# - These environment variables are for system-level SMS (optional)
# - Schools pay directly to SMS providers (Africa's Talking/Twilio)

# SchoolPay Configuration:
# - Each school needs their own SchoolPay merchant account
# - Configure in Admin Panel > Settings > SchoolPay Integration
# - Real-time mobile money payments (MTN, Airtel)

# Security:
# - Use strong passwords (min 32 characters for JWT_SECRET)
# - Enable SSL/TLS in production (Caddy handles this automatically)
# - Rotate secrets regularly
# - Never commit .env.production to version control
