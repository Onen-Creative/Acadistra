# PostgreSQL Configuration
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=acadistra

# Redis Configuration
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# JWT Configuration (minimum 64 characters recommended)
JWT_SECRET=CHANGE_THIS_TO_VERY_LONG_SECURE_SECRET_MIN_64_CHARS

# Application Configuration
ENVIRONMENT=production

# Optional: SMS Integration (Africa's Talking)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
AFRICASTALKING_SENDER_ID=

# Optional: Email Configuration
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Optional: Mobile Money Integration
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# Multi-Tenant Architecture
# All schools share one database (acadistra)
# Data is isolated by school_id column in each table
# Subdomain routing handled by Caddy and backend middleware
